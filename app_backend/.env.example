# App
APP_NAME=Welligton API
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4200,http://127.0.0.1:4200

# -----------------------------------------------------------------------------
# DATABASE_URL — Alembic/uvicorn no Windows (fora do Docker)
#
# Host: 127.0.0.1 — nunca use "db" aqui (só existe dentro da rede Docker).
#
# PORTA: o docker-compose publica o Postgres do container em 127.0.0.1:5433 por padrão
# (POSTGRES_PORT=5433), para NÃO bater com um PostgreSQL instalado no Windows na 5432.
# Se você conectar na 5432 e usar app/app, pode estar falando com o Postgres LOCAL
# (outro usuário/senha) → "autenticação falhou para o usuário app".
#
# Credenciais padrão do serviço `db` no Compose: app / app / appdb
DATABASE_URL=postgresql+asyncpg://app:app@127.0.0.1:5433/appdb

# JWT — use SECRET_KEY (ou JWT_SECRET_KEY como alias)
SECRET_KEY=sua_chave_secreta_longa_e_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Porta publicada no host (opcional; padrão no compose é 5433)
# POSTGRES_PORT=5433

# Opcional — mesmo padrão do serviço `db` no docker-compose.yml
# POSTGRES_USER=app
# POSTGRES_PASSWORD=app
# POSTGRES_DB=appdb

# RabbitMQ (docker-compose)
# AMQP: 5672 | Painel: 15672
# Se rodar API local (fora Docker), use 127.0.0.1.
RABBITMQ_URL=amqp://app:app@127.0.0.1:5672/%2f
# RABBITMQ_PORT=5672
# RABBITMQ_MANAGEMENT_PORT=15672
# RABBITMQ_DEFAULT_USER=app
# RABBITMQ_DEFAULT_PASS=app

# MongoDB (auditoria assíncrona)
# Se rodar API local (fora Docker), use 127.0.0.1.
MONGO_URI=mongodb://app:app@127.0.0.1:27017
MONGO_AUDIT_DB=auditdb
MONGO_AUDIT_COLLECTION=product_events
# MONGO_PORT=27017
# MONGO_INITDB_ROOT_USERNAME=app
# MONGO_INITDB_ROOT_PASSWORD=app

# Mongo Express (interface web)
# MONGO_EXPRESS_PORT=8081
# MONGO_EXPRESS_USERNAME=admin
# MONGO_EXPRESS_PASSWORD=admin
